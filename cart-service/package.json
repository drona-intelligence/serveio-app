  },
  "homepage": "https://github.com/drona-intelligence/serveio-app#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
