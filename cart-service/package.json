{
  "name": "cart-service",
  "version": "1.0.0",
  "description": "Cart management microservice for Serveio",
  "main": "index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b && node --env-file=.env dist/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:integration:watch": "vitest tests/integration",
    "test:unit": "vitest run tests --exclude tests/integration"
  },
